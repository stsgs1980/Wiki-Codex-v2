# =============================================================================
# Wiki Codex - Environment Configuration
# =============================================================================
#
# For LOCAL DEVELOPMENT with Docker PostgreSQL:
#   DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wiki_codex
#
# For VERCEL DEPLOYMENT (use one of these managed PostgreSQL providers):
#
#   1. Vercel Postgres (recommended):
#      DATABASE_URL="postgres://default:xxxxx@ep-xxx.us-east-1.aws.neon.tech/wiki_codex?sslmode=require"
#
#   2. Neon (free tier available):
#      DATABASE_URL="postgresql://user:pass@ep-xxx.neon.tech/wiki_codex?sslmode=require"
#
#   3. Supabase:
#      DATABASE_URL="postgresql://postgres:xxxxx@db.xxxx.supabase.co:5432/postgres"
#
#   4. PlanetScale:
#      DATABASE_URL="mysql://user:pass@aws.connect.psdb.cloud/wiki_codex?sslaccept=strict"
#      (Note: requires schema.prisma provider = "mysql")
#
# =============================================================================

# Local development (Docker PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wiki_codex

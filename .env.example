# PostgreSQL connection string (REQUIRED for both local dev and production)
# Local:    postgresql://postgres:postgres@localhost:5432/wiki_codex
# Vercel:   Set DATABASE_URL in Vercel dashboard (Neon, Supabase, etc.)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wiki_codex
